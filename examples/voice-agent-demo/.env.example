# Copy this file to `.env` and fill in the value(s). `.env` is git-ignored.
#
#   cp .env.example .env
#
# ── BACKEND SECRET (token server only) ────────────────────────────────────
# Your AssemblyAI API key. The token server (token-server.js) reads this to
# mint short-lived tokens. It is NEVER shipped to the app.
# IMPORTANT: do not prefix this with EXPO_PUBLIC_ — that would bundle it into
# the client. Get a key at https://www.assemblyai.com/app/api-keys
ASSEMBLYAI_API_KEY=

# ── CLIENT CONFIG (safe to ship) ──────────────────────────────────────────
# Where the app fetches ephemeral tokens from. Points at the token server.
# On a physical device use your machine's LAN IP, not localhost.
EXPO_PUBLIC_TOKEN_ENDPOINT=http://localhost:8787
