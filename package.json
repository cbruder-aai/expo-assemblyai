{
  "name": "expo-assemblyai",
  "version": "0.1.0",
  "description": "React Native / Expo SDK for AssemblyAI — bidirectional (two-way) streaming audio for voice agents, live speech-to-text, plus async transcription and the LLM Gateway. Native mic capture with echo cancellation and speaker playback, wrapped in a hook.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "open -a \"Xcode\" examples/voice-agent-demo/ios",
    "open:android": "open -a \"Android Studio\" examples/voice-agent-demo/android"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-module",
    "assemblyai",
    "speech-to-text",
    "stt",
    "transcription",
    "streaming",
    "voice-agent",
    "two-way-audio",
    "bidirectional-audio",
    "realtime",
    "audio",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AssemblyAI/expo-assemblyai"
  },
  "bugs": {
    "url": "https://github.com/AssemblyAI/expo-assemblyai/issues"
  },
  "homepage": "https://github.com/AssemblyAI/expo-assemblyai#readme",
  "author": "AssemblyAI <support@assemblyai.com>",
  "license": "MIT",
  "files": [
    "build",
    "android/src",
    "android/build.gradle",
    "ios/**/*.swift",
    "ios/**/*.podspec",
    "expo-module.config.json",
    "app.plugin.js",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@expo/config-plugins": "^57.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "~19.0.0",
    "expo-module-scripts": "^4.0.0",
    "expo-modules-core": "^2.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
